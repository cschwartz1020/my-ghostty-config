# Ghostty Configuration

# Background transparency (0.0 = fully transparent, 1.0 = fully opaque)
# Slightly transparent background
background-opacity = 0.85

# Optional: Uncomment to enable blur effect behind transparent window
# background-blur-radius = 20

# Dim inactive panes to highlight the active one (0.15 to 1.0)
# Lower values = more dimming on inactive panes
unfocused-split-opacity = 0.3

# Make cursor thicker (value is pixels to add)
adjust-cursor-thickness = 4

# Equalize split sizes
keybind = cmd+shift+a=equalize_splits

# Limit scrollback to reduce memory usage (default is 10000)
scrollback-limit = 5000
